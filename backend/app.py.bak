# ─── Doctors ──────────────────────────────────────────────────────────────────

@app.route('/doctors/add', methods=['GET', 'POST'])
@admin_required
def doctor_add():

    if request.method == 'GET':
        departments = Department.query.all()
        return jsonify({
            "departments": [d.to_dict() for d in departments]
        }), 200

    current_user      = get_current_user()
    data              = request.get_json()
    name              = data.get('name', '').strip()
    qualification     = data.get('qualification', '').strip()
    experience_years  = data.get('experience_years')
    specialization_id = data.get('specialization_id')
    phone             = data.get('phone', '').strip()
    email             = data.get('email', '').strip()

    availability_entries = data.get('availability', [])

    department = db.session.get(Department, specialization_id)
    if not department:
        return jsonify({"message": "Selected department does not exist"}), 400
    if not all([name, qualification, experience_years, phone]):
        return jsonify({"message": "Name, qualification, experience, and phone are mandatory"}), 400
    if len(phone) > 15:
        return jsonify({"message": "Phone cannot be more than 15 characters"}), 400

    username = (
        name.replace(" ", "").lower() +
        str(experience_years).replace(" ", "").lower() +
        str(phone).replace(" ", "").lower()
    )
    if User.query.filter_by(username=username).first():
        return jsonify({"message": "Generated username already exists, please adjust input"}), 400

    new_user = User(username=username, passhash=generate_password_hash(username), email=email, role='doctor')
    db.session.add(new_user)
    db.session.flush()

    doctor = Doctor(
        user_id=new_user.id, name=name,
        department_id=department.id, specialization=department.name,
        qualification=qualification, experience_years=experience_years,
        phone=phone, blacklisted=False
    )
    db.session.add(doctor)
    db.session.flush()

    for entry in availability_entries:
        date_str            = entry.get('date')
        morning_slot_status = entry.get('morning_slot_status', 'not available')
        evening_slot_status = entry.get('evening_slot_status', 'not available')
        if date_str:
            try:
                date = datetime.strptime(date_str, '%Y-%m-%d').date()
                availability = Availability(
                    date=date,
                    morning_slot_status=morning_slot_status,
                    evening_slot_status=evening_slot_status,
                    doctor_id=doctor.id
                )
                db.session.add(availability)
            except ValueError:
                continue

    db.session.commit()

    return jsonify({
        "message":    "Doctor added successfully",
        "doctor":     doctor.to_dict(),
        "created_by": current_user.username
    }), 201


