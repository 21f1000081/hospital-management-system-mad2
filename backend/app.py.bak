    }), 200

# ─── Appointments ─────────────────────────────────────────────────────────────

@app.route('/appointment/<int:doctor_id>', methods=['POST'])
@role_required(['patient'])
def appointment(doctor_id):
    current_user = get_current_user()
    doctor       = Doctor.query.get_or_404(doctor_id)
    patient      = Patient.query.filter_by(user_id=current_user.id).first()

    if not patient:
        return jsonify({"message": "Patient profile not found"}), 404
    if doctor.blacklisted:
        return jsonify({"message": "This doctor is not available for appointments"}), 403

    available_spots = Availability.query.filter_by(doctor_id=doctor.id).all()
    if not available_spots:
        return jsonify({"message": f"No available spots for Dr. {doctor.name}"}), 404

    data          = request.get_json()
    selected_date = data.get('date')
    selected_time = data.get('time', '').lower().strip()

    if not selected_date or not selected_time:
        return jsonify({"message": "Date and time are required"}), 400

    # FIX 4: parse date string to a date object for consistent querying
    try:
        selected_date_obj = datetime.strptime(selected_date, '%Y-%m-%d').date()
    except ValueError:
        return jsonify({"message": "Invalid date format. Use YYYY-MM-DD"}), 400

    avail = Availability.query.filter_by(doctor_id=doctor.id, date=selected_date_obj).first()
    if not avail:
        return jsonify({"message": "Selected date not available"}), 400

    if selected_time == "morning":
        if avail.morning_slot_status == "Booked":
            return jsonify({"message": "Morning slot already booked"}), 400
        avail.morning_slot_status = "Booked"
    elif selected_time == "evening":
        if avail.evening_slot_status == "Booked":
            return jsonify({"message": "Evening slot already booked"}), 400
        avail.evening_slot_status = "Booked"
    else:
        return jsonify({"message": "Invalid time slot. Use 'morning' or 'evening'"}), 400

    new_appointment = Appointment(
        patient_id=patient.id, doctor_id=doctor_id,
        date=selected_date_obj,  # FIX 4: use parsed date object
        time=selected_time,
        type="In-person", status="Booked"
    )
    db.session.add(new_appointment)
    db.session.commit()

    return jsonify({
        "message":     "Appointment booked successfully",
        "appointment": new_appointment.to_dict(),
        "doctor":      doctor.to_dict(),
        "patient":     patient.to_dict()
    }), 201


@app.route('/cancel_appointment/<int:appointment_id>', methods=['PATCH'])
@role_required(['patient'])
def cancel_appointment(appointment_id):
    current_user = get_current_user()
    appointment  = Appointment.query.get_or_404(appointment_id)
    doctor       = Doctor.query.get_or_404(appointment.doctor_id)
    patient      = Patient.query.filter_by(user_id=current_user.id).first()

    if not patient or patient.id != appointment.patient_id:
        return jsonify({"message": "You can only cancel your own appointments"}), 403
    if appointment.status == "Cancelled":
        return jsonify({"message": "Appointment is already cancelled"}), 400

    appointment.status = "Cancelled"

    avail = Availability.query.filter_by(doctor_id=doctor.id, date=appointment.date).first()
    if avail:
        time_lower = appointment.time.lower()
        if time_lower == "morning":
            avail.morning_slot_status = "available"
        elif time_lower == "evening":
            avail.evening_slot_status = "available"

    db.session.commit()

    return jsonify({
        "message":     "Appointment cancelled successfully",
        "appointment": appointment.to_dict(),
        "doctor":      doctor.to_dict(),
        "patient":     patient.to_dict(),
        "department":  Department.query.get_or_404(doctor.department_id).to_dict()
    }), 200


@app.route('/mark_completed/<int:appointment_id>', methods=['PATCH'])
@role_required(['doctor'])
def mark_completed(appointment_id):
    current_user = get_current_user()
    appointment  = Appointment.query.get_or_404(appointment_id)

    if appointment.status == "Cancelled":
        return jsonify({"message": "Cannot complete a cancelled appointment"}), 400

    appointment.status = "Completed"
    db.session.commit()

    return jsonify({
        "message":     "Appointment marked as completed",
        "appointment": appointment.to_dict(),
        "updated_by":  current_user.username
    }), 200


@app.route('/appointment_cancelled/<int:appointment_id>', methods=['PATCH'])
@role_required(['doctor'])
def appointment_cancelled(appointment_id):
    current_user = get_current_user()
    appointment  = Appointment.query.get_or_404(appointment_id)

    if appointment.status == "Cancelled":
        return jsonify({"message": "Appointment is already cancelled"}), 400

    appointment.status = "Cancelled"
    db.session.commit()

    return jsonify({
        "message":     "Appointment cancelled",
        "appointment": appointment.to_dict(),
        "updated_by":  current_user.username
    }), 200

# ─── Treatment / Patient History Update ───────────────────────────────────────

@app.route('/update_patient_history/<int:appointment_id>', methods=['PATCH'])
@role_required(['doctor'])
def update_patient_history(appointment_id):
    current_user = get_current_user()
    appointment  = Appointment.query.get_or_404(appointment_id)
    patient      = Patient.query.get_or_404(appointment.patient_id)
    doctor       = Doctor.query.get_or_404(appointment.doctor_id)

    data = request.get_json()
    if not data:
        return jsonify({"message": "Request must be JSON"}), 400

    tests        = data.get('tests')
    diagnosis    = data.get('diagnosis')
    prescription = data.get('prescription')
    updated_at   = datetime.today().date()

    treatment = Treatment.query.filter_by(appointment_id=appointment.id).first()

    if treatment:
        for med in Medicine.query.filter_by(treatment_id=treatment.id).all():
            db.session.delete(med)
        treatment.tests        = tests
        treatment.diagnosis    = diagnosis
        treatment.prescription = prescription
        treatment.updated_at   = updated_at
    else:
        treatment = Treatment(
            appointment_id=appointment.id, tests=tests,
            diagnosis=diagnosis, prescription=prescription,
            updated_at=updated_at
        )
        db.session.add(treatment)
        db.session.flush()

    new_meds = []
    for med in data.get('medicines', []):
        new_med = Medicine(
            treatment_id=treatment.id,
            name=med.get('name'),
            dosage_morning=med.get('dosage_morning'),
            dosage_day=med.get('dosage_day'),
            dosage_night=med.get('dosage_night')
        )
        db.session.add(new_med)
        new_meds.append(new_med)

    db.session.commit()  # FIX 6: commit before calling to_dict() so medicines have IDs

    return jsonify({
        "message":     "Patient history updated",
        "appointment": appointment.to_dict(),
        "patient":     patient.to_dict(),
        "doctor":      doctor.to_dict(),
        "treatment":   treatment.to_dict(),
        "medicines":   [m.to_dict() for m in new_meds],  # IDs now available post-commit
        "updated_by":  current_user.username
    }), 200

