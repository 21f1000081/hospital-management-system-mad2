@app.route('/patient/patient_dashboard/<int:id>', methods=['GET'])
@role_required(['admin', 'doctor', 'patient'])
def patient_dashboard(id):
    current_user = get_current_user()
    patient      = Patient.query.get_or_404(id)
    departments  = Department.query.all()
    appointments = Appointment.query.filter(
        Appointment.patient_id == id,
        Appointment.status     == 'Booked',
        Appointment.date       >= datetime.now().date()
    ).all()
    doctor_ids          = {appt.doctor_id for appt in appointments}
    doctors_for_patient = Doctor.query.filter(Doctor.id.in_(doctor_ids)).all()

    return jsonify({
        "user":         current_user.to_dict(),
        "patient":      patient.to_dict(),
        "departments":  [d.to_dict()   for d   in departments],
        "appointments": [a.to_dict()   for a   in appointments],
        "doctors":      [doc.to_dict() for doc in doctors_for_patient]
    }), 200


@app.route('/patient/blacklist/<int:id>', methods=['PATCH'])
@admin_required
def patient_blacklist(id):
    current_user = get_current_user()
    patient      = Patient.query.get_or_404(id)

    patient.blacklisted = not patient.blacklisted
    db.session.commit()

    return jsonify({
        "message":    "Patient blacklisted successfully" if patient.blacklisted else "Patient unblocked successfully",
        "patient":    patient.to_dict(),
        "updated_by": current_user.username
    }), 200

# ─── Patient History ──────────────────────────────────────────────────────────

@app.route('/patient_history_doctor/<int:doctor_id>/<int:patient_id>', methods=['GET'])
@role_required(['admin', 'doctor'])
def patient_history_doctor(doctor_id, patient_id):
    current_user = get_current_user()
    doctor       = Doctor.query.get_or_404(doctor_id)
    patient      = Patient.query.get_or_404(patient_id)

    appointments = Appointment.query.filter_by(doctor_id=doctor_id, patient_id=patient_id).all()
    treatments   = Treatment.query.join(Treatment.appointment).filter(
        Appointment.doctor_id  == doctor_id,
        Appointment.patient_id == patient_id
    ).all()

    return jsonify({
        "user":         current_user.to_dict(),
        "doctor":       doctor.to_dict(),
        "patient":      patient.to_dict(),
        "appointments": [a.to_dict() for a in appointments],
        "treatments":   [t.to_dict() for t in treatments]
    }), 200


@app.route('/patient_history/<int:patient_id>', methods=['GET'])
@role_required(['admin', 'doctor', 'patient'])
def patient_history(patient_id):
    current_user   = get_current_user()
    patient        = Patient.query.get_or_404(patient_id)
    appointments   = Appointment.query.filter_by(patient_id=patient_id).all()
    doctor_ids     = {appt.doctor_id for appt in appointments}
    doctors        = Doctor.query.filter(Doctor.id.in_(doctor_ids)).all()
    department_ids = {doc.department_id for doc in doctors}
    departments    = Department.query.filter(Department.id.in_(department_ids)).all()
    treatments     = Treatment.query.join(Treatment.appointment).filter(
        Appointment.doctor_id.in_(doctor_ids),
        Appointment.patient_id == patient_id
    ).all()

    return jsonify({
        "user":         current_user.to_dict(),
        "patient":      patient.to_dict(),
        "appointments": [a.to_dict()   for a   in appointments],
        "doctors":      [d.to_dict()   for d   in doctors],
        "departments":  [dep.to_dict() for dep in departments],
        "treatments":   [t.to_dict()   for t   in treatments]
    }), 200

