# ─── JWT Helpers ──────────────────────────────────────────────────────────────

def current_username():
    """Plain string — the JWT subject."""
    return get_jwt_identity()

def current_role():
    """Role stored in JWT additional_claims."""
    return get_jwt().get('role')

def get_current_user():
    """Fetch the User row for the logged-in user."""
    return User.query.filter_by(username=current_username()).first()

# ─── Role decorators ──────────────────────────────────────────────────────────

def role_required(roles):
    def wrapper(fn):
        @wraps(fn)
        @jwt_required()
        def decorated(*args, **kwargs):
            if current_role() not in roles:
                return jsonify({"message": "Access forbidden"}), 403
            return fn(*args, **kwargs)
        return decorated
    return wrapper

def admin_required(fn):
    @wraps(fn)
    @jwt_required()
    def wrapper(*args, **kwargs):
        if current_role() != 'admin':
            return jsonify({"message": "Admins only"}), 403
        return fn(*args, **kwargs)
    return wrapper

# ─── Home / Search ────────────────────────────────────────────────────────────

@app.route('/', methods=['GET'])
@jwt_required()
def home():
    user = get_current_user()
    if not user:
        return jsonify({"message": "User not found"}), 404

    query = request.args.get('query', '').strip()

    if query:
        # Doctor search
        doctor = Doctor.query.filter(Doctor.name.ilike(f'%{query}%')).first()
        if doctor:
            department = Department.query.get(doctor.department_id)
            appointments = Appointment.query.filter(
                Appointment.doctor_id == doctor.id,
                Appointment.date >= datetime.now().date()
            ).all()
            patient_ids = {appt.patient_id for appt in appointments}
            patients = Patient.query.filter(Patient.id.in_(patient_ids)).all()
            return jsonify({
                "user": user.username,
                "doctors": [doctor.name],
                "patients": [p.name for p in patients],
                "departments": [department.name] if department else [],
                "appointments": [{"id": a.id, "date": a.date.isoformat()} for a in appointments]
            }), 200

        # Department search
        department = Department.query.filter(Department.name.ilike(f'%{query}%')).first()
        if department:
            doctors = Doctor.query.filter_by(department_id=department.id).all()
            doctor_ids = [doc.id for doc in doctors]
            appointments = Appointment.query.filter(
                Appointment.doctor_id.in_(doctor_ids),
                Appointment.date >= datetime.now().date()
            ).all()
            patient_ids = {appt.patient_id for appt in appointments}
            patients = Patient.query.filter(Patient.id.in_(patient_ids)).all()
            return jsonify({
                "user": user.username,
                "doctors": [d.name for d in doctors],
                "patients": [p.name for p in patients],
                "departments": [department.name],
                "appointments": [{"id": a.id, "date": a.date.isoformat()} for a in appointments]
            }), 200

        # Patient search
        patient = Patient.query.filter(Patient.name.ilike(f'%{query}%')).first()
        if patient:
            appointments = Appointment.query.filter(
                Appointment.patient_id == patient.id,
                Appointment.date >= datetime.now().date()
            ).all()
            doctor_ids = {appt.doctor_id for appt in appointments}
            doctors = Doctor.query.filter(Doctor.id.in_(doctor_ids)).all()
            department_ids = {doc.department_id for doc in doctors}
            departments = Department.query.filter(Department.id.in_(department_ids)).all()
            return jsonify({
                "user": user.username,
                "doctors": [d.name for d in doctors],
                "patients": [patient.name],
                "departments": [dep.name for dep in departments],
                "appointments": [{"id": a.id, "date": a.date.isoformat()} for a in appointments]
            }), 200

        return jsonify({"message": "No results found for your query"}), 404

    # Role-based responses
    role = current_role()

    if role == 'admin':
        return jsonify({"message": "Redirect to admin dashboard"}), 200

    elif role == 'patient':
        patient = Patient.query.filter_by(user_id=user.id).first()
        if not patient:
            return jsonify({"message": "Patient profile not found"}), 404
        user_appointments = Appointment.query.filter(
            Appointment.patient_id == patient.id,
            Appointment.date >= datetime.now().date()
        ).all()
        return jsonify({
            "message": "Redirect to patient dashboard",
            "appointments": [{"id": a.id, "date": a.date.isoformat()} for a in user_appointments]
        }), 200

    elif role == 'doctor':
        doctor = Doctor.query.filter_by(user_id=user.id).first()
        if not doctor:
            return jsonify({"message": "Doctor profile not found"}), 404
        return jsonify({
            "message": "Redirect to doctor dashboard",
            "doctor_id": doctor.id
        }), 200

    # Fallback
    doctors = Doctor.query.all()
    patients = Patient.query.all()
    departments = Department.query.all()
    return jsonify({
        "user": user.username,
        "doctors": [d.name for d in doctors],
        "patients": [p.name for p in patients],
        "departments": [dep.name for dep in departments],
        "appointments": []
    }), 200

# ─── Auth ─────────────────────────────────────────────────────────────────────

@app.route('/register', methods=['POST'])
def register():
    data = request.get_json()
    if not data:
        return jsonify({"message": "Request must be JSON"}), 400

    username = data.get('username', '').strip()
    password = data.get('password', '').strip()
    email    = data.get('email', '').strip()
    role = 'patient'

    if not all([username, password, email, role]):
        return jsonify({"message": "All fields are required"}), 400

    if User.query.filter_by(username=username).first():
        return jsonify({"message": "Username already exists"}), 400

    new_user = User(
        username=username,
        email=email,
        passhash=generate_password_hash(password),
        role=role
    )
    db.session.add(new_user)
    db.session.commit()

    access_token = create_access_token(
        identity=new_user.username,
        additional_claims={"role": role}
    )

    # If you want to auto‑login the patient, return user_info too
    return jsonify({
        "message": "User created successfully",
        "access_token": access_token,
        "user_info": {
            "id": new_user.id,
            "username": new_user.username,
            "email": new_user.email,
            "role": new_user.role,
            "patient_id": None  # you can resolve Patient.id here if you create it immediately
        }
    }), 201

@app.route('/login', methods=['POST'])
def login():
    data     = request.get_json()
    if not data:
        return jsonify({"message": "Request must be JSON"}), 400

    username = data.get('username', '').strip()
    password = data.get('password', '')

    if not username or not password:
        return jsonify({"message": "Username and password are required"}), 400

    user = User.query.filter_by(username=username).first()
    if user is None or not user.check_password(password):
        return jsonify({'message': 'Invalid credentials'}), 401

    access_token = create_access_token(
        identity=user.username,
        additional_claims={"role": user.role}
    )
    
    # ✅ resolve patient_id so Vue can redirect to /patient/<patient_id>
    patient_id = None
    if user.role == 'patient':
        patient = Patient.query.filter_by(user_id=user.id).first()
        patient_id = patient.user_id if patient else None

    return jsonify(
        access_token=access_token,
        user_info={
            'id':         user.id,
            'username':   user.username,
            'email':      user.email,
            'role':       user.role,
            'patient_id': patient_id
        }
    ), 200

@app.route('/logout', methods=['POST'])
@jwt_required()
def logout():
    response = jsonify({"message": "You have been logged out"})
    unset_jwt_cookies(response)
    return response, 200

# ─── Admin ────────────────────────────────────────────────────────────────────

@app.route('/admin', methods=['GET'])
@admin_required
def admin():
    user         = get_current_user()
    users        = User.query.all()
    doctors      = Doctor.query.all()
    appointments = Appointment.query.filter(
        Appointment.date >= datetime.now().date(),
        Appointment.status == 'Booked'
    ).all()
    departments = Department.query.all()
    patients    = Patient.query.all()

    return jsonify({
        "user":         user.to_dict(),
        "users":        [u.to_dict()   for u   in users],
        "doctors":      [d.to_dict()   for d   in doctors],
        "appointments": [a.to_dict()   for a   in appointments],
        "departments":  [dep.to_dict() for dep in departments],
        "patients":     [p.to_dict()   for p   in patients],
        "messages": {
            "doctors":      "No doctor found"      if not doctors      else None,
            "appointments": "No appointment found" if not appointments else None,
            "departments":  "No department found"  if not departments  else None,
            "patients":     "No patient found"     if not patients     else None,
        }
    }), 200


