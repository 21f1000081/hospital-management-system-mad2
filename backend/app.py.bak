# ─── Patients ─────────────────────────────────────────────────────────────────
@app.route('/patient/add', methods=['POST'])
@role_required(['patient'])
def patient_add():
    current_user = get_current_user()
    data    = request.get_json()
    name    = data.get('name', '').strip()
    dob     = data.get('dob', '').strip()
    phone   = data.get('phone', '').strip()
    address = data.get('address', '').strip()

    if not all([name, dob, phone, address]):
        return jsonify({"message": "All fields are mandatory"}), 400
    try:
        dob_date = datetime.strptime(dob, "%Y-%m-%d").date()
    except ValueError:
        return jsonify({"message": "Invalid date format for Date of Birth"}), 400
    if len(phone) > 15:
        return jsonify({"message": "Phone cannot be more than 15 characters"}), 400
    if len(address) > 250:
        return jsonify({"message": "Address cannot be more than 250 characters"}), 400

    dob_date = datetime.strptime(dob, "%Y-%m-%d").date()

    patient = Patient(
        user_id=current_user.id,
        name=name, dob=dob_date,
        phone=phone, address=address, blacklisted=False
    )
    db.session.add(patient)
    db.session.commit()

    return jsonify({
        "message":    "Patient added successfully",
        "patient":    patient.to_dict(),
        "created_by": current_user.username
    }), 201


