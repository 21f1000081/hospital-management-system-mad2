    with app.app_context():
        db.create_all()
        if not User.query.filter_by(role="admin").first():
            admin_user = User(
                username="admin",
                passhash=generate_password_hash("admin"),
                role="admin",
                email="admin@aa.com"
            )
            db.session.add(admin_user)
            db.session.commit()
    app.run(debug=True)