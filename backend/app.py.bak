@app.route('/doctors/doctors_dashboard/<int:id>', methods=['GET'])
@role_required(['doctor', 'admin'])
def doctors_dashboard(id):
    current_user = get_current_user()

    # Fix: look up by user_id so the URL /doctors/doctors_dashboard/<user_id> works correctly
    doctor = Doctor.query.filter_by(user_id=id).first_or_404()

    appointments = Appointment.query.filter(
        Appointment.doctor_id == doctor.id,
        Appointment.date >= datetime.now().date()
    ).all()
    patient_ids = {appt.patient_id for appt in appointments}
    patients    = Patient.query.filter(Patient.id.in_(patient_ids)).all()

    return jsonify({
        "user":         current_user.to_dict(),
        "doctor":       doctor.to_dict(),
        "appointments": [a.to_dict() for a in appointments],
        "patients":     [p.to_dict() for p in patients]
    }), 200


@app.route('/doctors/doctors_availability/<int:id>', methods=['GET', 'POST'])
@role_required(['doctor', 'admin'])
def doctors_availability(id):
    # Fix: look up by user_id to match the id passed in the URL
    doctor = Doctor.query.get_or_404(id)

    if request.method == 'GET':
        availability = Availability.query.filter_by(doctor_id=doctor.id).all()
        return jsonify([{
            "date":                avail.date.isoformat(),
            "morning_slot_status": avail.morning_slot_status,
            "evening_slot_status": avail.evening_slot_status
        } for avail in availability])

    data = request.get_json()
    if not data:
        return jsonify({"message": "Request must be JSON"}), 400

    for entry in data.get("availability", []):
        try:
            date = datetime.strptime(entry["date"], "%Y-%m-%d").date()
        except (ValueError, KeyError):
            return jsonify({"message": f"Invalid date format in entry: {entry}"}), 400

        avail = Availability.query.filter_by(doctor_id=doctor.id, date=date).first()
        if not avail:
            avail = Availability(doctor_id=doctor.id, date=date)
            db.session.add(avail)
        if avail.morning_slot_status != 'Booked':
            avail.morning_slot_status = entry.get("morning_slot_status", "not available")
        if avail.evening_slot_status != 'Booked':
            avail.evening_slot_status = entry.get("evening_slot_status", "not available")

    db.session.commit()
    return jsonify({"doctor": doctor.to_dict(), "success": True, "message": "Availability updated successfully"})


